# Copy to migration/.env before running the importer.
# LOCAL values come from `supabase status` (use the SERVICE ROLE key, not anon).

SUPABASE_URL=http://127.0.0.1:54321
SERVICE_ROLE_KEY=your-local-service-role-key
EXPORT_DIR=./export
# Comma-separated emails to flag as admins after import:
ADMIN_EMAILS=m3220298@gmail.com
