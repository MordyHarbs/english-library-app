# Edge Function secrets. Copy to supabase/functions/.env for local function testing.
# In production these are set via `supabase secrets set ...` (never committed).

# Gmail SMTP (free). Requires 2FA on the account + an App Password.
GMAIL_USER=ayalotlibrary@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Base URL used for deep links in admin emails.
SITE_URL=http://localhost:5173

# Where new-reservation alerts go (usually the same as GMAIL_USER).
ADMIN_EMAIL=ayalotlibrary@gmail.com

# Google Drive backups. The refresh token needs Drive file access so the function
# can create folders/files in the deploying Google account's Drive.
GOOGLE_DRIVE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=your-google-oauth-refresh-token
